#include <stdlib.h>

int* beautifulArray(int n, int* returnSize) {

    int* result = (int*)malloc(n * sizeof(int));
    int size = 1;

    result[0] = 1;

    while (size < n) {

        int* temp = (int*)malloc(n * sizeof(int));
        int idx = 0;

        // Generate odd numbers
        for (int i = 0; i < size; i++) {
            int val = 2 * result[i] - 1;

            if (val <= n) {
                temp[idx++] = val;
            }
        }

        // Generate even numbers
        for (int i = 0; i < size; i++) {
            int val = 2 * result[i];

            if (val <= n) {
                temp[idx++] = val;
            }
        }

        free(result);

        result = temp;
        size = idx;
    }

    *returnSize = n;

    return result;
}
