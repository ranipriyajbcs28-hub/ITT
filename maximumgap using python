class Solution(object):
    def maximumGap(self, nums):
        if len(nums) < 2:
            return 0
        nums.sort()
        max_diff = 0
        for i in range(len(nums) - 1):
            current_diff = nums[i+1] - nums[i]
            if current_diff > max_diff:
                max_diff = current_diff
        return max_diff
