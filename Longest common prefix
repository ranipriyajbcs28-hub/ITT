class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        if not strs: return ""
        for i in range(len(strs[0])):
            char = strs[0][i]
            for others in strs[1:]:
                if i == len(others) or others[i] != char:
                    return strs[0][:i]
                    
        return strs[0]
